[gd_scene load_steps=7 format=3]

[ext_resource type="Script" path="res://MultiplayerMenu.cs" id="1_script"]
[ext_resource type="Theme" path="res://resources/ui_menu_theme.tres" id="2_theme"]

[sub_resource type="Shader" id="Shader_background"]
code = "shader_type canvas_item;

float hash(vec2 p) {
	return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453);
}

void fragment() {
	vec3 base = vec3(0.006, 0.014, 0.055);
	float halo = 1.0 - smoothstep(0.0, 0.78, distance(UV, vec2(0.5, 0.48)));
	vec2 cells = floor(UV * vec2(80.0, 46.0));
	float stars = step(0.992, hash(cells + floor(TIME * 0.12)));
	float scan = sin(UV.y * 780.0 + TIME) * 0.004;
	vec3 color = base + vec3(0.018, 0.052, 0.11) * halo + vec3(0.18, 0.66, 0.95) * stars * 0.25 + scan;
	COLOR = vec4(color, 1.0);
}"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_background"]
