[sub_resource type="Shader" id="Shader_background"]
code = "shader_type canvas_item;

void fragment() {
	vec3 navy = vec3(0.006, 0.014, 0.055);
	float left_glow = 1.0 - smoothstep(0.0, 0.8, distance(UV, vec2(0.24, 0.52)));
	float right_glow = 1.0 - smoothstep(0.0, 0.66, distance(UV, vec2(0.82, 0.38)));
	float lines = sin((UV.x + UV.y) * 460.0 + TIME * 0.8) * 0.004;
	vec3 color = navy + vec3(0.01, 0.07, 0.14) * left_glow + vec3(0.09, 0.03, 0.11) * right_glow + lines;
	COLOR = vec4(color, 1.0);
}"

