[sub_resource type="Shader" id="Shader_background"]
code = "shader_type canvas_item;

void fragment() {
	vec4 source = texture(TEXTURE, UV);
	float vignette = smoothstep(0.94, 0.26, distance(UV, vec2(0.5)));
	float pulse = 0.98 + sin(TIME * 0.45) * 0.02;
	vec3 graded = source.rgb * vec3(0.9, 0.95, 1.08) * pulse;
	COLOR = vec4(graded * mix(0.62, 1.0, vignette), source.a);
}"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_background"]
shader = SubResource("Shader_background")

[sub_resource type="Shader" id="Shader_atmosphere"]
code = "shader_type canvas_item;

void fragment() {
	float edge = smoothstep(0.38, 1.0, abs(UV.x - 0.5) * 2.0);
	float bottom = smoothstep(0.7, 1.0, UV.y);
	float scan = sin(UV.y * 820.0 + TIME * 1.2) * 0.009;
	float center = 1.0 - smoothstep(0.0, 0.34, distance(UV, vec2(0.5, 0.61)));
	vec3 navy = vec3(0.006, 0.014, 0.055);
	float alpha = 0.08 + edge * 0.22 + bottom * 0.76 + scan - center * 0.08;
	COLOR = vec4(navy, clamp(alpha, 0.02, 0.9));
}"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_atmosphere"]
shader = SubResource("Shader_atmosphere")

