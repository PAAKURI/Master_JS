[sub_resource type="Shader" id="Shader_damage_edges"]
code = "shader_type canvas_item;
void fragment() {
	float edge = min(min(UV.x, 1.0 - UV.x), min(UV.y, 1.0 - UV.y));
	float alpha = 1.0 - smoothstep(0.0, 0.12, edge);
	COLOR = vec4(0.8, 0.0, 0.0, alpha * 0.5);
}"

[sub_resource type="ShaderMaterial" id="DamageMaterial"]
